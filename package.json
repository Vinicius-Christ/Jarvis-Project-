{
  "name": "jarvis-system-suite",
  "private": true,
  "version": "1.0.0",
  "description": "Sistema Jarvis Residencial e IA",
  "author": "Vinícius",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "clean": "rm -rf dist server.js release",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.jarvis.desktop.suite",
    "productName": "JARVIS Suite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "asar": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "systeminformation": "^5.31.7",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.10"
  }
}
